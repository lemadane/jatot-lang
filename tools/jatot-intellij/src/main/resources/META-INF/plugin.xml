<idea-plugin>
    <id>io.jatot.intellij</id>
    <name>Jatot Language Support</name>
    <vendor email="support@jatot.io" url="https://jatot.io">Jatot Project</vendor>

    <description><![CDATA[
    IDE integration and custom language support for the Jatot programming language on the IntelliJ Platform.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Jatot"
                  implementationClass="io.jatot.intellij.JatotFileType"
                  fieldName="INSTANCE"
                  extensions="jatot"/>

        <lang.commenter language="Jatot"
                        implementationClass="io.jatot.intellij.JatotCommenter"/>

        <lang.braceMatcher language="Jatot"
                           implementationClass="io.jatot.intellij.JatotBraceMatcher"/>

        <completion.contributor language="Jatot"
                                implementationClass="io.jatot.intellij.JatotCompletionContributor"/>
    </extensions>
</idea-plugin>
