{
  "name": "jatot-vscode",
  "displayName": "Jatot Language Support",
  "description": "IDE support for the Jatot programming language",
  "version": "0.1.0",
  "publisher": "io.jatot",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:jatot"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "jatot",
        "aliases": [
          "Jatot",
          "jatot"
        ],
        "extensions": [
          ".jatot"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jatot",
        "scopeName": "source.jatot",
        "path": "./syntaxes/jatot.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "jatot.showGeneratedJava",
        "title": "Jatot: Show Generated Java"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Jatot Configuration",
      "properties": {
        "jatot.compiler.path": {
          "type": "string",
          "default": "",
          "description": "Path to the Jatot compiler jar."
        },
        "jatot.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the Jatot language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^16.18.34",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.4"
  }
}
