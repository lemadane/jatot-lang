{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Jatot",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#interpolated-strings"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#html-tags"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#annotations"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.jatot",
          "match": "//.*$"
        },
        {
          "name": "comment.block.jatot",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.jatot",
          "match": "\\b(if|else|for|while|do|try|catch|finally|throw|return|yield|break|continue|async|await|generator|emit)\\b"
        },
        {
          "name": "storage.type.jatot",
          "match": "\\b(class|interface|record|enum|extension|void|int|long|double|float|boolean|char|byte|short)\\b"
        },
        {
          "name": "storage.modifier.jatot",
          "match": "\\b(public|private|protected|static|final|transient|volatile|synchronized|native|abstract|strictfp)\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.declaration.annotation.jatot",
          "match": "@[a-zA-Z0-9_.]+"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.jatot",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.jatot",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "interpolated-strings": {
      "patterns": [
        {
          "name": "string.quoted.double.interpolated.jatot",
          "begin": "\\$\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.jatot",
              "match": "\\\\."
            },
            {
              "include": "#interpolation-expression"
            }
          ]
        }
      ]
    },
    "interpolation-expression": {
      "begin": "\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.interpolation.begin.jatot"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.interpolation.end.jatot"
        }
      },
      "name": "meta.interpolation.jatot",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    "html-tags": {
      "patterns": [
        {
          "name": "meta.embedded.block.html.jatot",
          "begin": "<([a-zA-Z0-9:-]+)(?=\\s|>|/>)",
          "beginCaptures": {
            "1": {
              "name": "entity.name.tag.jatot"
            }
          },
          "end": "(/?>)",
          "patterns": [
            {
              "name": "entity.other.attribute-name.jatot",
              "match": "\\b([a-zA-Z0-9:-]+)\\s*="
            },
            {
              "include": "#interpolation-expression"
            },
            {
              "include": "#strings"
            }
          ]
        },
        {
          "name": "meta.embedded.block.html.jatot",
          "begin": "</([a-zA-Z0-9:-]+)>",
          "beginCaptures": {
            "1": {
              "name": "entity.name.tag.jatot"
            }
          },
          "end": "(?=>)"
        }
      ]
    }
  },
  "scopeName": "source.jatot"
}
